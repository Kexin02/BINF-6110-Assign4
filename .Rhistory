gene_list <- de_cluster$avg_log2FC
names(gene_list) <- de_cluster$gene
gene_list <- gene_list[!is.na(gene_list)]
gene_list <- sort(gene_list, decreasing = TRUE)
gene_list <- gene_list[names(gene_list) %in% keys(org.Mm.eg.db, keytype = "SYMBOL")]
if (length(gene_list) > 10) {
gsea_res <- gseGO(
geneList = gene_list,
OrgDb = org.Mm.eg.db,
keyType = "SYMBOL",
ont = "BP"
)
print(dotplot(gsea_res, showCategory = 15))
}
Idents(data_rm) <- "seurat_clusters"
de_cluster <- FindMarkers(
data_rm,
ident.1 = as.character(cluster_of_interest),
only.pos = FALSE,
logfc.threshold = 0.25,
min.pct = 0.25,
max.cells.per.ident = 2000
)
de_cluster <- de_cluster %>%
rownames_to_column("gene") %>%
arrange(p_val_adj, desc(avg_log2FC))
print(head(de_cluster, 20))
gene_list <- de_cluster$avg_log2FC
names(gene_list) <- de_cluster$gene
gene_list <- gene_list[!is.na(gene_list)]
gene_list <- sort(gene_list, decreasing = TRUE)
gene_list <- gene_list[names(gene_list) %in% keys(org.Mm.eg.db, keytype = "SYMBOL")]
if (length(gene_list) > 10) {
gsea_res <- gseGO(
geneList = gene_list,
OrgDb = org.Mm.eg.db,
keyType = "SYMBOL",
ont = "BP"
)
print(dotplot(gsea_res, showCategory = 15))
}
gene_list <- de_cluster$avg_log2FC
names(gene_list) <- de_cluster$gene
gene_list <- gene_list[!is.na(gene_list)]
gene_list <- sort(gene_list, decreasing = TRUE)
gene_list <- gene_list[names(gene_list) %in% keys(org.Mm.eg.db, keytype = "SYMBOL")]
if (length(gene_list) > 10) {
gsea_res <- gseGO(
geneList = gene_list,
OrgDb = org.Mm.eg.db,
keyType = "SYMBOL",
ont = "BP",
pvalueCutoff = 0.05
)
# Inspect enrichment table
gsea_df <- as.data.frame(gsea_res)
print(head(gsea_df, 20))
if (nrow(gsea_df) > 0) {
p_gsea <- dotplot(gsea_res, showCategory = 12) +
theme_minimal(base_size = 12) +
theme(
axis.text.y = element_text(size = 10),
plot.title = element_text(hjust = 0.5)
) +
labs(
title = "GSEA of cluster 24 marker genes",
x = "Gene Ratio",
y = NULL
) +
scale_y_discrete(labels = function(x) stringr::str_wrap(x, width = 30))
print(p_gsea)
# Optional: save figure
# ggsave("cluster24_GSEA_dotplot.png", p_gsea, width = 10, height = 6)
} else {
message("No significant GSEA terms found.")
}
} else {
message("Not enough genes available for GSEA.")
}
top_genes <- de_cluster %>%
filter(p_val_adj < 0.05) %>%
slice_max(order_by = avg_log2FC, n = 20) %>%
pull(gene)
top_genes <- intersect(top_genes, rownames(data_rm))
DoHeatmap(
data_rm,
features = top_genes,
group.by = "celltype"
) +
scale_fill_gradientn(colors = c("navy", "white", "firebrick3")) +
theme(axis.text.y = element_text(size = 6))
top_genes <- de_cluster %>%
filter(p_val_adj < 0.05) %>%
slice_max(order_by = avg_log2FC, n = 15) %>%
pull(gene)
top_genes <- intersect(top_genes, rownames(data_rm))
# average expression by annotated cell type
avg_exp <- AverageExpression(
data_rm,
assays = "RNA",
features = top_genes,
group.by = "celltype",
slot = "data"
)$RNA
# z-score by gene for nicer visualization
avg_exp_scaled <- t(scale(t(avg_exp)))
avg_exp_scaled[is.na(avg_exp_scaled)] <- 0
# optional: control column order
desired_order <- c(
"Epithelial",
"IFN_epithelial",
"Myeloid",
"Olfactory_neuron",
"Remodeling_epithelial",
"T_cells"
)
desired_order <- intersect(desired_order, colnames(avg_exp_scaled))
avg_exp_scaled <- avg_exp_scaled[, desired_order, drop = FALSE]
pheatmap(
avg_exp_scaled,
cluster_rows = TRUE,
cluster_cols = FALSE,
fontsize_row = 10,
fontsize_col = 12,
angle_col = 45,
border_color = NA,
main = "Top marker genes of remodeling epithelial cells"
)

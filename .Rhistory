Idents(data_rm) <- "seurat_clusters"
# representative marker genes for cluster 24
marker_panel <- c("Krt13", "Krt6b", "Plet1", "Csta1", "Prss27", "Calml3", "Pglyrp4")
marker_panel <- intersect(marker_panel, rownames(data_rm))
# reorder clusters so cluster 24 appears first (top after coord_flip)
cluster_levels <- levels(Idents(data_rm))
cluster_levels <- c("24", setdiff(cluster_levels, "24"))
Idents(data_rm) <- factor(Idents(data_rm), levels = cluster_levels)
# make plot
p_dot <- DotPlot(
data_rm,
features = marker_panel,
group.by = "seurat_clusters",
cols = c("grey90", "mediumpurple2", "blue3")
) +
coord_flip() +
theme_minimal(base_size = 13) +
labs(
title = "Expression of representative cluster 24 marker genes",
x = NULL,
y = "Cluster"
) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text.x = element_text(size = 10),
axis.text.y = element_text(size = 10),
panel.grid.major = element_line(color = "grey85"),
panel.grid.minor = element_blank(),
legend.position = "right"
) +
geom_hline(
yintercept = 1,
linetype = "dashed",
color = "red",
linewidth = 0.6
) +
annotate(
"text",
x = length(marker_panel) + 0.25,
y = 1.3,
label = "Cluster 24",
color = "red",
size = 4,
hjust = 0
)
print(p_dot)

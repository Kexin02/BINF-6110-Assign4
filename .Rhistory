celltype_prop <- data_rm@meta.data %>%
group_by(time, celltype) %>%
summarise(n = n(), .groups = "drop") %>%
group_by(time) %>%
mutate(freq = n / sum(n))
p_comp <- ggplot(celltype_prop, aes(x = time, y = freq, fill = celltype)) +
geom_bar(stat = "identity") +
theme_minimal(base_size = 13) +
labs(
title = "Cell type composition across time",
x = "Time",
y = "Proportion"
) +
scale_fill_brewer(palette = "Set2")
print(p_comp)

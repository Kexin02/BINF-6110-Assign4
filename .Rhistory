ont = "BP"
)
print(dotplot(gsea_res, showCategory = 15))
}
sig_up_genes <- de_cluster %>%
filter(p_val_adj < 0.05, avg_log2FC > 0) %>%
pull(gene)
# Keep only valid mouse gene symbols
sig_up_genes <- intersect(sig_up_genes, keys(org.Mm.eg.db, keytype = "SYMBOL"))
if (length(sig_up_genes) > 0) {
ora_res <- enrichGO(
gene = sig_up_genes,
OrgDb = org.Mm.eg.db,
keyType = "SYMBOL",
ont = "BP",
pAdjustMethod = "BH"
)
